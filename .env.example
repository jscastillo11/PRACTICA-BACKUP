# Copia a ".env" o exporta en la shell antes de arrancar Flask / spark-submit.
# Despliegue todo con Docker: ver README sección "Docker Compose" (`docker compose up --build -d`).

# Raíz del repo (donde están models/, resources/, flight_prediction/)
FLIGHT_PREDICTOR_BASE_PATH=C:/ruta/completa/a/PRACTICA-IBDN-Vuelos-Docker
# Misma idea que el README para otros scripts
PROJECT_HOME=C:/ruta/completa/a/PRACTICA-IBDN-Vuelos-Docker

# Kafka (lista separada por comas si varios brokers)
# Con docker-compose.yml de este repo: Flask en el host → localhost:9092 (PLAINTEXT_HOST).
# Servicios dentro de la misma red Docker → kafka:19092 (PLAINTEXT, imagen apache/kafka).
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PREDICTION_TOPIC=flight-delay-ml-request

# Mongo — Flask (pymongo)
MONGO_URI=mongodb://127.0.0.1:27017/

# Mongo — conector Spark → Mongo (streaming sink)
MONGO_SPARK_URI=mongodb://127.0.0.1:27017

# Checkpoint Spark Structured Streaming (en Windows puede convenir una ruta local)
SPARK_CHECKPOINT_DIR=C:/tmp/flight-predictor-checkpoint

# --- Valores típicos cuando TODO corre dentro de docker-compose (red interna) ---
# KAFKA_BOOTSTRAP_SERVERS=kafka:19092
# MONGO_URI=mongodb://mongo:27017/
# MONGO_SPARK_URI=mongodb://mongo:27017
# FLIGHT_PREDICTOR_BASE_PATH=/opt/practica

